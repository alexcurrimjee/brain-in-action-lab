<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">

        <img src="/images/brain.svg" alt="Brain in Action Lab" class="footer__logo" />
        <p class="footer__name">BRAIN IN ACTION LAB</p>
        <p class="footer__lead">Dr. Silvia Seghezzi</p>

    </div>
    <div class="footer__contact">
      <p class="footer__affiliation">Birkbeck, University of London</p>
      <p class="footer__address">Malet Street, Bloomsbury, London WC1E 7HX</p>
      <p><a href="mailto:s.seghezzi@bbk.ac.uk">s.seghezzi@bbk.ac.uk</a></p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 4rem 1.5rem;
    margin-top: auto;
    background: var(--color-bg-dark);
    color: white;
  }

  .footer__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .footer__logo {
    width: 64px;
    height: auto;
    flex-shrink: 0;

  }

  .footer__lead {
    color: var(--color-accent);
    font-size: 0.875rem;
  }

  .footer__name {
    letter-spacing: 0.05em;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .footer__affiliation {
    font-weight: 600;
    font-size: 1.25rem;
  }

  .footer__contact {
    text-align: right;
    font-size: 0.875rem;
    color: var(--color-text-dark);
    line-height: 1.8;
  }

  .footer__address {
    font-size: 0.875rem;
    color: var(--color-text-secondary-dark);
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .footer__inner {
      flex-direction: column;
    }
    .footer__contact {
      text-align: left;
    }
  }
</style>
