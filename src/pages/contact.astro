---
import BaseLayout from '../layouts/BaseLayout.astro';
import yaml from 'js-yaml';
import { readFileSync } from 'fs';

const site = yaml.load(readFileSync('src/data/site.yaml', 'utf-8')) as any;
---

<BaseLayout title="Contact">
  <div class="page-header">
    <h1>Contact</h1>
  </div>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-block">
          <h2>Address</h2>
          <address>
            <p>{site.address.line1}</p>
            <p>{site.address.line2}</p>
            <p>{site.address.line3}</p>
            <p>Office: {site.address.office}</p>
          </address>
        </div>

        <div class="contact-block">
          <h2>Contact</h2>
          <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
          <p class="contact-note">
            If you are interested in joining the lab, please include a brief statement of your research interests and a CV.
          </p>
        </div>

        <div class="contact-block">
          <h2>Links</h2>
          <ul class="link-list">
            {site.links.map((link: any) => (
              <li>
                <a href={link.url} target="_blank" rel="noopener">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3rem;
  }

  .contact-block {
    border: 1px solid var(--color-border-light);
    border-radius: 24px;
    padding: 1.5rem;
    background: var(--color-bg-alt);
  }

  .contact-block h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
  }

  .contact-block address {
    font-style: normal;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  .contact-block p {
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 0.25rem;
  }

  .contact-note {
    margin-top: 1rem;
    font-size: 0.875rem;
  }

  .link-list {
    list-style: none;
    padding: 0;
  }

  .link-list li {
    margin-bottom: 0.5rem;
  }

  .link-list a {
    font-weight: 500;
  }
</style>
