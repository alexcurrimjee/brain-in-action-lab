---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact">
  <div class="page-header">
    <h1>Contact</h1>
  </div>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-block">
          <h2>Address</h2>
          <address>
            <p>Birkbeck, University of London</p>
            <p>Malet Street, Bloomsbury</p>
            <p>London WC1E 7HX</p>
            <p>Office: 517b</p>
          </address>
        </div>

        <div class="contact-block">
          <h2>Contact</h2>
          <p><a href="mailto:s.seghezzi@bbk.ac.uk">s.seghezzi@bbk.ac.uk</a></p>
          <p class="contact-note">
            If you are interested in joining the lab, please include a brief statement of your research interests and a CV.
          </p>
        </div>

        <div class="contact-block">
          <h2>Links</h2>
          <ul class="link-list">
            <li>
              <a href="https://scholar.google.co.uk/citations?user=7M2d-DsAAAAJ&hl=en&oi=ao" target="_blank" rel="noopener">Google Scholar</a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3rem;
  }

  .contact-block {
    border: 1px solid var(--color-border-light);
    border-radius: 24px;
    padding: 1.5rem;
    background: var(--color-bg-alt);
  }

  .contact-block h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;    
  }

  .contact-block address {
    font-style: normal;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  .contact-block p {
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 0.25rem;
  }

  .contact-note {
    margin-top: 1rem;
    font-size: 0.875rem;
  }

  .link-list {
    list-style: none;
    padding: 0;
  }

  .link-list li {
    margin-bottom: 0.5rem;
  }

  .link-list a {
    font-weight: 500;
  }
</style>
