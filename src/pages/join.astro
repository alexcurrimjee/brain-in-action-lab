---
import BaseLayout from '../layouts/BaseLayout.astro';
import yaml from 'js-yaml';
import { readFileSync } from 'fs';

const data = yaml.load(readFileSync('src/data/join.yaml', 'utf-8')) as any;
---

<BaseLayout title="Join the Lab">
  <div class="page-header">
    <h1>Join the Lab</h1>
    <p>{data.intro}</p>
  </div>

  <section class="section">
    <div class="container">
      <div class="prose">
        <p>{data.description}</p>
        <p>{data.contact_note}</p>
      </div>

      <div class="opportunities">
        {data.opportunities.map((opp: any) => (
          <div class="opportunity">
            <h2>{opp.title}</h2>
            {opp.body.trim().split(/\n\s*\n/).map((p: string) => (
              <p>{p.trim()}</p>
            ))}
            {opp.list && (
              <ul>
                {opp.list.map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
            )}
            {opp.footer && <p>{opp.footer}</p>}
          </div>
        ))}
      </div>

      <div class="contact-box">
        <h3>{data.contact_box.heading}</h3>
        <p>{data.contact_box.text}</p>
        <ul>
          {data.contact_box.items.map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
        <a href={data.contact_box.button_url} class="btn btn--primary">{data.contact_box.button_text}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .prose p {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .opportunities {
    margin-top: 2.5rem;
  }

  .opportunity {
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .opportunity:last-child {
    border-bottom: none;
  }

  .opportunity h2 {
    margin-bottom: 1rem;
  }

  .opportunity p {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 0.75rem;
  }

  .opportunity ul {
    margin: 0.5rem 0 1rem 1.5rem;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.8;
  }

  .contact-box {
    padding: 2rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    max-width: 560px;
    margin: 3rem auto 0;
  }

  .contact-box h3 {
    margin-bottom: 0.75rem;
  }

  .contact-box p {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }

  .contact-box ul {
    margin: 0.5rem 0 1.25rem 1.5rem;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.8;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.5rem;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn--primary {
    background: var(--color-accent);
    color: white;
  }

  .btn--primary:hover {
    background: var(--color-accent-hover);
    color: white;
  }
</style>
