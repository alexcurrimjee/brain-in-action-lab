---
import BaseLayout from '../layouts/BaseLayout.astro';

const photos = [
  { src: 'IMG_0331.jpeg', alt: 'Lab Life photo' },
  { src: 'IMG_2096.jpeg', alt: 'Lab Life photo' },
  { src: 'IMG_2165.jpeg', alt: 'Lab Life photo' },
  { src: 'IMG_3851.jpeg', alt: 'Lab Life photo' },
  { src: 'IMG_5307.jpeg', alt: 'Lab Life photo' },
  { src: 'IMG_5705.jpeg', alt: 'Lab Life photo' },
  { src: 'IMG_5716.jpeg', alt: 'Lab Life photo' },
  { src: 'IMG_6281.jpeg', alt: 'Lab Life photo' },
  { src: 'IMG_6703.jpeg', alt: 'Lab Life photo' },
  { src: 'd8fb4e0a-2ec3-4cc7-b161-7302a6f06a3f.jpeg', alt: 'Lab Life photo' },
];
---
<BaseLayout title="Lab Life">
  <div class="page-header">
    <h1>Lab Life</h1>
    <p class="page-header__subtitle">Snapshots of our science in action.</p>
  </div>
  <section class="section">
    <div class="container">
      <div class="photo-grid">
        {photos.map(photo => (
          <div class="photo-grid__item">
            <img
              src={`${import.meta.env.BASE_URL}images/lab-life/${photo.src}`}
              alt={photo.alt}
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header__subtitle {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    margin-top: 0.5rem;
  }
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .photo-grid__item {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 4px;
    background: var(--color-border);
  }
  .photo-grid__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .photo-grid__item:hover img {
    transform: scale(1.03);
  }
  @media (max-width: 768px) {
    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .photo-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
