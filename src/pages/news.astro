---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const news = (await getCollection('news')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="News">
  <div class="page-header">
    <h1>News</h1>
  </div>

  <section class="section">
    <div class="container">
      {news.map(item => (
        <article class="news-item">
          <time class="news-item__date" datetime={item.data.date.toISOString()}>
            {item.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
          </time>
          <h3 class="news-item__title">
            {item.data.url ? (
              <a href={item.data.url} target="_blank" rel="noopener">{item.data.title}</a>
            ) : (
              item.data.title
            )}
          </h3>
          <p class="news-item__summary">{item.data.summary}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .news-item {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .news-item:first-child {
    padding-top: 0;
  }

  .news-item:last-child {
    border-bottom: none;
  }

  .news-item__date {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 500;
  }

  .news-item__title {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0.5rem 0;
  }

  .news-item__summary {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.7;

  }
</style>
