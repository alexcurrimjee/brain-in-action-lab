---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationCard from '../components/PublicationCard.astro';
import { getCollection } from 'astro:content';

const pubs = (await getCollection('publications')).sort((a, b) => b.data.year - a.data.year);

const underReview = pubs.filter(p => p.data.status === 'under-review' || p.data.status === 'preprint');
const published = pubs.filter(p => p.data.status === 'published');
---

<BaseLayout title="Publications">
  <div class="page-header">
    <h1>Publications</h1>
    <p>
      For a full list, see <a href="https://scholar.google.co.uk/citations?user=7M2d-DsAAAAJ&hl=en&oi=ao" target="_blank" rel="noopener">Google Scholar</a>.
    </p>
  </div>

  {underReview.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="pub-section__title">Under Review & Preprints</h2>
        {underReview.map(pub => (
          <PublicationCard
            title={pub.data.title}
            authors={pub.data.authors}
            journal={pub.data.journal}
            conference={pub.data.conference}
            year={pub.data.year}
            doi={pub.data.doi}
            url={pub.data.url}
            pdf={pub.data.pdf}
            type={pub.data.type}
            status={pub.data.status}
          />
        ))}
      </div>
    </section>
  )}

  <section class={underReview.length > 0 ? "section section--alt" : "section"}>
    <div class="container">
      <h2 class="pub-section__title">Published Articles</h2>
      {published.map(pub => (
        <PublicationCard
          title={pub.data.title}
          authors={pub.data.authors}
          journal={pub.data.journal}
          conference={pub.data.conference}
          year={pub.data.year}
          doi={pub.data.doi}
          url={pub.data.url}
          pdf={pub.data.pdf}
          type={pub.data.type}
          status={pub.data.status}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .pub-section__title {
    margin-bottom: 0.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--color-border);
  }
</style>
