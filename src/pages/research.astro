---
import BaseLayout from '../layouts/BaseLayout.astro';
import yaml from 'js-yaml';
import { readFileSync } from 'fs';

const data = yaml.load(readFileSync('src/data/research.yaml', 'utf-8')) as any;
---

<BaseLayout title="Research">
  <div class="page-header">
    <h1>Research</h1>
    <p>{data.intro}</p>
  </div>

  <section class="section">
    <div class="container">
      <div class="research-themes">
        {data.themes.map((theme: any) => (
          <article class="research-theme">
            <div class="research-theme__label">{theme.label}</div>
            <h2>{theme.title}</h2>
            <p>{theme.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <h2 class="approach__title">{data.approach.title}</h2>
      <h3 class="approach__subtitle">{data.approach.subtitle}</h3>
      <div class="approach__text">
        {data.approach.paragraphs.map((p: string) => (
          <p>{p}</p>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .research-themes {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .research-theme {
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    align-items: start;
  }

  .research-theme:first-child {
    padding-top: 0;
  }

  .research-theme:last-child {
    border-bottom: none;
  }

  .research-theme__label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
    background: var(--color-accent-bg);
    padding: 0.2em 0.5em;
    border-radius: 4px;
  }

  .research-theme h2 {
    font-size: 1.35rem;
    margin-bottom: 1rem;
  }

  .research-theme p {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .approach__title {
    margin-bottom: 0.25rem;
  }

  .approach__subtitle {
    color: var(--color-text-secondary);
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .approach__text p {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .approach__text p:last-child {
    margin-bottom: 0;
  }
</style>
