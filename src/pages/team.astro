---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import yaml from 'js-yaml';
import { readFileSync } from 'fs';

const culture = yaml.load(readFileSync('src/data/culture.yaml', 'utf-8')) as any;
const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const rendered = await Promise.all(
  team.map(async (member) => {
    const { Content } = await render(member);
    return { member, Content };
  })
);
---

<BaseLayout title="Team & Culture">
  <div class="page-header">
    <h1>Team & Culture</h1>
  </div>

  <!-- Team members -->
  <section class="section">
    <div class="container team-container">
      {rendered.map(({ member, Content }) => (
        <div class="team-card">
          {member.data.photo && (
            <div class="team-card__photo-wrap">
              <img src={`${base}${member.data.photo.replace(/^\//, '')}`} alt={member.data.name} class="team-card__photo" loading="lazy" />
            </div>
          )}
          <div class="team-card__info">
            <h3 class="team-card__name">{member.data.name}</h3>
            <p class="team-card__role team-card__role-badge">{member.data.role}</p>
            <div class="team-card__bio">
              <Content />
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Culture: What We Value -->
  <section class="section">
    <div class="container">
      <h2>What We Value</h2>
      <p class="culture-intro">{culture.intro}</p>

      <div class="values">
        {culture.values.map((v: any) => (
          <div class="value">
            <h3>{v.title}</h3>
            <p>{v.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Diversity and Inclusion -->
  <section class="section section--alt">
    <div class="container">
      <h2>{culture.diversity.title}</h2>
      <div class="prose">
        {culture.diversity.paragraphs.map((p: string) => (
          <p>{p}</p>
        ))}
        <p>We actively promote an inclusive research environment by:</p>
        <ul>
          {culture.diversity.practices.map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
        <p>{culture.diversity.closing}</p>
      </div>
    </div>
  </section>

  <!-- Lab Life -->
  <section class="section">
    <div class="container">
      <h2>{culture.lab_life.title}</h2>
      <div class="prose">
        {culture.lab_life.paragraphs.map((p: string) => (
          <p>{p}</p>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .team-container {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .team-card {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 2.5rem;
    padding: 2rem;
    background: var(--color-bg-alt);
    border-radius: 24px;
    border: 1px solid var(--color-border-light);
  }

  .team-card:last-child {
    border-bottom: none;
  }

  .team-card__photo-wrap {
    width: 240px;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 12px;
  }

  .team-card__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .team-card__info{
    display: flex;
    flex-direction: column;
    align-items: start;
  }

  .team-card__name {
    font-size: 1.35rem;
    margin-bottom: 0.25rem;
  }

  .team-card__role {
    color: var(--color-accent);
    font-size: 0.925rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .team-card__role-badge {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2em 0.5em;
    border-radius: 4px;
    white-space: nowrap;   
    background: var(--color-accent-bg);
    color: var(--color-accent);
  }

  .team-card__bio {
    font-size: 0.925rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .team-card__bio :global(p) {
    margin-bottom: 0.75rem;
  }

  .team-card__bio :global(p:last-child) {
    margin-bottom: 0;
  }

  .culture-intro {
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 0.5rem;
  }

  .values {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 1.5rem;
  }

  .value {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .value:last-child {
    border-bottom: none;
  }

  .value h3 {
    font-size: 1.05rem;
    margin-bottom: 0.75rem;
  }

  .value p {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.8;

    margin-bottom: 0.75rem;
  }

  .value p:last-child {
    margin-bottom: 0;
  }

  .prose p {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .prose ul {
    margin: 0.75rem 0 1rem 1.5rem;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.8;
  }

  .prose li {
    margin-bottom: 0.25rem;
  }

  @media (max-width: 768px) {
    .team-card {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .team-card__photo-wrap {
      width: 180px;
      aspect-ratio: 1;
      border-radius: 50%;
    }
  }
</style>
